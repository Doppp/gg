{
  "name": "gg",
  "version": "0.1.0",
  "description": "Good game. Every time.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "gg": "dist/cli.js",
    "gg-tui": "dist/tui/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:tui": "tsx src/tui/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run --exclude test/tui-e2e.test.ts",
    "test:watch": "vitest",
    "test:e2e": "vitest run test/e2e-cli.test.ts",
    "test:e2e:tui": "npm run build && vitest run test/tui-e2e.test.ts",
    "demo:e2e": "tsx scripts/e2e-smoke.ts",
    "demo:e2e:tui": "npm run build && tsx scripts/e2e-tui-smoke.ts",
    "demo:e2e:real": "tsx scripts/e2e-real-agents.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "better-sqlite3": "^11.10.0",
    "execa": "^9.6.0",
    "ink": "^5.1.0",
    "minimist": "^1.2.8",
    "react": "^18.3.1",
    "simple-git": "^3.28.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.14",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
